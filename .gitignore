# =============================================================
# Entorno Virtual de Python
# =============================================================
venv/
.venv/
env/
ENV/

# =============================================================
# Cache de Python
# =============================================================
__pycache__/
**/__pycache__/
*$py.class
*.pyc
*.pyo
*.pyd
**/*.py[cod]

# =============================================================
# Variables de Entorno y Configuración Local
# =============================================================
.env
*.env
.env.*
!.env.example

# =============================================================
# Archivos Temporales del Sistema Operativo
# =============================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# =============================================================
# VS Code
# =============================================================
.vscode/
!.vscode/extensions.json

# =============================================================
# Jupyter Notebooks — Checkpoints
# =============================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# =============================================================
# Distribución y Empaquetado de Python
# =============================================================
dist/
build/
*.egg-info/
*.egg
wheels/

# =============================================================
# Herramientas de Testing y Cobertura
# =============================================================
.pytest_cache/
.coverage
htmlcov/

# =============================================================
# Google Drive
# =============================================================
*.gdoc
*.gsheet
*.gslides
*.gdraw
desktop.ini
~$*
*.tmp
Icon\r
.tmp.driveupload/
.tmp.drivedownload

# =============================================================
# Logs y Archivos Temporales de la Aplicación
# =============================================================
*.log
logs/
*.tmp
*.bak
*.swp

# =============================================================
# Uploads (archivos subidos por usuarios en runtime)
# =============================================================
static/uploads/*
!static/uploads/.gitkeep
static/docs/*
!static/docs/.gitkeep
static/metrics/*
!static/metrics/.gitkeep
static/temp/*
!static/temp/.gitkeep

# =============================================================
# Herramientas de IA para desarrollo (VS Code y otras)
# =============================================================
# Claude Code
.claude/

# GitHub Copilot
.copilot/

# Cursor
.cursor/
.cursorignore

# Continue
.continue/

# Codeium
.codeium/

