# Conexión a MongoDB local y nombre de la base de datos y colección principal
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=proyecto_bigData
MONGO_COLECCION=usuario_roles

# URL y credenciales de Elasticsearch local
# ELASTIC_INDEX_DEFAULT define el índice que usa la aplicación por defecto
# ELASTIC_STARTUP_TIMEOUT define los segundos máximos para esperar que Elasticsearch arranque
ELASTIC_URL=http://localhost:9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=your_elastic_password_here
ELASTIC_INDEX_DEFAULT=index_minagricultura
ELASTIC_STARTUP_TIMEOUT=120

# Clave secreta de Flask para firmar sesiones y tokens CSRF
# Directorio donde se almacenan los archivos subidos por los usuarios
SECRET_KEY=your_secret_key_here
UPLOAD_DIR=static/uploads

# Credenciales del usuario administrador inicial de la aplicación
# Usadas por init_db.py — cambie estos valores antes de ejecutarlo en producción
APP_USER_ADMIN=admin
APP_USER_ADMIN_PASSWORD=your_admin_password_here
